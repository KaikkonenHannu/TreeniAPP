# TreeniAI Environment Variables

# Server
PORT=3000

# Database
DB_PATH=./data/treeni.db

# AI API Keys (at least one required for program generation)
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# YouTube Data API v3 (optional, for exercise videos)
YOUTUBE_API_KEY=AIzaxxxxx

# Push Notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@treeni-ai.app

# Cron endpoint protection (optional)
CRON_SECRET=your-secret-here
